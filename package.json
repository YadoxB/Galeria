{
  "name": "galerie-app",
  "version": "0.8.0",
  "private": true,
  "description": "Logiciel de gestion pour galeries d'art",
  "author": "Galeria",
  "license": "UNLICENSED",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "reset-db": "node scripts/reset-db.js",
    "import-photos-oeuvres": "node scripts/import-photos-oeuvres.js",
    "prepare:icon": "node scripts/build-icon.js",
    "prepare:seed": "node scripts/build-seed.js",
    "prepare:seed:vide": "node scripts/build-seed-vide.js",
    "prepare:photos": "node scripts/build-photos-seed.js",
    "prepare:photos:vide": "node scripts/build-photos-seed-vide.js",
    "prepare:assets:complet": "npm run prepare:icon && npm run prepare:seed && npm run prepare:photos && node scripts/pack-photos.js",
    "prepare:assets:public": "npm run prepare:icon && npm run prepare:seed:vide && npm run prepare:photos:vide",
    "prepare:assets:catalogue": "npm run prepare:icon && node scripts/build-seed-catalogue.js && node scripts/pack-photos.js",
    "build:complet": "npm run prepare:assets:complet && electron-builder --win",
    "build:public": "npm run prepare:assets:public && electron-builder --win --publish=never",
    "build:catalogue": "npm run prepare:assets:catalogue && electron-builder --win --publish=never",
    "release": "node scripts/release.js",
    "build": "npm run build:complet"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "csv-parse": "^6.2.1",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.gvsj.galeria",
    "productName": "Galeria",
    "copyright": "Copyright © 2026 Galeria",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "gabarits/**/*",
      "package.json",
      "!**/*.{md,log,csv}",
      "!imports-airtable/**",
      "!scripts/**"
    ],
    "extraResources": [
      {
        "from": "seed",
        "to": "seed",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "seed-photos",
        "to": "seed-photos",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Galeria",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": false,
      "installerLanguages": ["fr_FR"],
      "displayLanguageSelector": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "YadoxB",
        "repo": "Galeria"
      }
    ]
  }
}
